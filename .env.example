NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=iot-claw
DEFAULT_TENANT=default
DEFAULT_SITE=default
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/iot_claw

INFLUXDB_URL=http://127.0.0.1:8086
INFLUXDB_TOKEN=replace-me
INFLUXDB_ORG=iot-claw
INFLUXDB_BUCKET=device_telemetry

MQTT_URL=mqtt://127.0.0.1:1883
MQTT_CLIENT_ID=iot-claw-server
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE_SECONDS=60
MQTT_TLS_ENABLED=false
MQTT_TOPIC_FILTER="iot/+/+/+/#"
MQTT_COMMAND_TOPIC_TEMPLATE=iot/{tenant}/{site}/{deviceId}/command/req
SAFE_WRITE_COMMANDS=restart,ping,sync_config,refresh_state
DANGEROUS_WRITE_COMMANDS=factory_reset,firmware_upgrade,shutdown

JOB_SCHEDULER_INTERVAL_MS=30000
AGENT_BRIDGE_DISPATCH_INTERVAL_MS=10000

AGENT_RUNTIME=openclaw
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION_KEY=main
OPENCLAW_CLIENT_ID=gateway-client

TELEMETRY_RETENTION_DAYS=30
