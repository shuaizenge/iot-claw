{
  "name": "iot-claw",
  "version": "0.0.5",
  "description": "IoT operations center built on NanoClaw concepts.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test:mqtt-connect": "tsx test/pc_Simulation/mqtt_connect.ts",
    "test:protocol-v1": "tsx test/pc_Simulation/protocol_test/protocol_v1_simulator.ts",
    "typecheck": "tsc --noEmit",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "cron-parser": "^5.4.0",
    "dotenv": "^16.6.1",
    "mqtt": "^5.14.1",
    "pg": "^8.16.3",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.2",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@types/pg": "^8.15.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
